// WeddingFilma – database schema
// Postgres via Supabase. Row Level Security is configured in supabase/migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  EDITOR
  PHOTOGRAPHER
  CLIENT
}

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventType {
  WEDDING
  PRE_WEDDING
  ENGAGEMENT
  MATERNITY
  CHILD
  CORPORATE
  PRODUCT
  EVENT
  OTHER
}

enum MediaType {
  IMAGE
  VIDEO
}

enum GalleryCategory {
  WEDDINGS
  PRE_WEDDING
  CHILD
  MATERNITY
  CORPORATE
  PRODUCT
  EVENT
}

model Profile {
  id        String   @id @db.Uuid // maps to auth.users.id
  email     String   @unique
  fullName  String?
  phone     String?
  role      Role     @default(CLIENT)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[] @relation("ClientBookings")

  @@map("profiles")
}

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  bookingCode     String        @unique
  clientId        String?       @db.Uuid
  fullName        String
  email           String
  phone           String
  eventType       EventType
  eventDate       DateTime
  venue           String?
  city            String
  budget          String?
  guestCount      Int?
  services        String[]      @default([])
  notes           String?
  status          BookingStatus @default(NEW)
  packageId       String?       @db.Uuid
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client  Profile? @relation("ClientBookings", fields: [clientId], references: [id], onDelete: SetNull)
  package Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([eventDate])
  @@map("bookings")
}

model GalleryItem {
  id          String          @id @default(uuid()) @db.Uuid
  title       String
  description String?
  category    GalleryCategory
  mediaType   MediaType       @default(IMAGE)
  url         String
  thumbnail   String?
  tags        String[]        @default([])
  featured    Boolean         @default(false)
  orderIndex  Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([featured])
  @@map("gallery_items")
}

model Testimonial {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  location   String?
  eventType  EventType
  rating     Int      @default(5)
  quote      String
  avatarUrl  String?
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("testimonials")
}

model Package {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  tagline     String?
  description String?
  priceFrom   Int
  currency    String   @default("INR")
  duration    String?
  includes    String[] @default([])
  popular     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("packages")
}

model ContactMessage {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model BlogPost {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  authorId    String?  @db.Uuid
  published   Boolean  @default(false)
  publishedAt DateTime?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@map("audit_logs")
}

model YearCapacity {
  year       Int      @id
  totalSlots Int      @default(12)
  booked     Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@map("year_capacity")
}
